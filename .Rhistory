calc_loo_new <- function (draws) {
if ('draws_array' %in% class(draws)) draws = apply(draws, c(1,3) ,mean) %>% as_tibble()
loglik = draws %>%
select(contains("log_lik")) %>%
select(where(~!any(is.na(.))))
out = list(loo::loo.array(posterior::as_draws_array(loglik)))
return(out)
}
